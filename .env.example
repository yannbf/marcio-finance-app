# Marcio environment — copy to .env.local and fill in.
# Never commit .env.local. The .gitignore already excludes it.

# --- Database --------------------------------------------------------------
# Neon Postgres connection string. Free tier: https://neon.com/pricing
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# --- Auth ------------------------------------------------------------------
# Better Auth signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Comma-separated list of allowed origins (e.g. http://localhost:3000)
MARCIO_TRUSTED_ORIGINS=http://localhost:3000

# Closed allow-list. Only these emails can request a magic link.
MARCIO_ALLOWED_EMAILS=
MARCIO_EMAIL_CAMILA=
MARCIO_EMAIL_YANN=

# --- Email (Resend) --------------------------------------------------------
# Free tier: 3000/month, 100/day. https://resend.com/pricing
RESEND_API_KEY=
MARCIO_FROM_EMAIL="Marcio <onboarding@resend.dev>"

# --- Bank-token encryption -------------------------------------------------
# 32-byte base64 key for libsodium secretbox over stored bank credentials.
# Generate with: openssl rand -base64 32
MARCIO_TOKEN_ENC_KEY=

# --- Google Sheets (Phase 1) -----------------------------------------------
# Service account JSON, base64-encoded:
#   cat svc.json | base64 | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_SHEET_ID=

# --- Bank sync v2 (Enable Banking, Phase 2b) -------------------------------
# Leave blank for Phase 2a (CSV-only ingest).
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_PRIVATE_KEY_B64=
