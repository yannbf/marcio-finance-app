    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:seed": "tsx tests/e2e/setup/seed.ts"
  },
  "dependencies": {
